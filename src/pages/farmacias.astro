---
import "../styles/global.css";
import { farmaciasInfo } from "../lib/generarTurnos";
import FloatingNav from "../components/FloatingNav";
import SecondaryPageInfo from "../components/SecondaryPageInfo.astro";
import Analytics from "@vercel/analytics/astro";

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=0, s-maxage=3600, stale-while-revalidate=86400"
);

const farmaciaEntries = Object.entries(farmaciasInfo);
const url = "https://farmaciadeturnomc.site";
const pageUrl = `${url}/farmacias`;
const imageUrl = `${url}/og-image.png`;

const slug = (key: string) => key.replace(/\s+/g, "-");

const title = "Farmacias Monte Caseros | Teléfonos y direcciones";
const description =
  "Directorio de farmacias en Monte Caseros, Corrientes: direcciones y teléfonos para llamar o visitar. Consultá también el calendario de turno y la farmacia de hoy.";

const jsonLdItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Farmacias — Monte Caseros",
  description,
  numberOfItems: farmaciaEntries.length,
  itemListElement: farmaciaEntries.map(([key, f], i) => {
    const hash = `farmacia-${slug(key)}`;
    const itemUrl = `${pageUrl}#${hash}`;
    return {
      "@type": "ListItem",
      position: i + 1,
      url: itemUrl,
      item: {
        "@type": "Pharmacy",
        name: f.nombre,
        url: itemUrl,
        telephone: f.telefono,
        address: {
          "@type": "PostalAddress",
          streetAddress: f.direccion,
          addressLocality: "Monte Caseros",
          addressRegion: "Corrientes",
          addressCountry: "AR",
        },
      },
    };
  }),
};

const jsonLdWebPage = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: title,
  description,
  url: pageUrl,
  inLanguage: "es-AR",
  isPartOf: { "@type": "WebSite", name: "Farmacias de Turno Monte Caseros", url },
};

const jsonLdBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Inicio", item: url },
    { "@type": "ListItem", position: 2, name: "Directorio de farmacias", item: pageUrl },
  ],
};

const jsonLdFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "¿Este listado incluye todas las farmacias de Monte Caseros?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Sí: reúne las farmacias del calendario local de turnos con dirección y teléfono para contactarlas desde el celular o la línea fija.",
      },
    },
    {
      "@type": "Question",
      name: "¿Cómo llamo a una farmacia desde el celular?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Tocá el número de teléfono en la ficha: se abrirá el marcador con el número listo para llamar.",
      },
    },
    {
      "@type": "Question",
      name: "¿Dónde veo el calendario de farmacia de turno de Monte Caseros?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "En la sección de próximos turnos del mismo sitio tenés las fechas ordenadas según el calendario oficial de Monte Caseros.",
      },
    },
  ],
};
---

<html lang="es-AR">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="language" content="es-AR" />
    <meta name="geo.region" content="AR-W" />
    <meta name="geo.placename" content="Monte Caseros" />
    <meta name="geo.position" content="-30.2539;-57.6363" />
    <meta name="ICBM" content="-30.2539, -57.6363" />
    <link rel="canonical" href={pageUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content="Farmacias de Turno Monte Caseros" />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={pageUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={imageUrl} />

    <meta name="theme-color" content="#166534" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Farmacias de Turno MC" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lora:wght@500;600&family=Outfit:wght@400;500;600&display=swap" rel="stylesheet" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebPage)} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdItemList)} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdFAQ)} />

    <style>
      :root {
        --green-950: #052e16;
        --green-900: #14532d;
        --green-800: #166534;
        --green-700: #15803d;
        --green-600: #16a34a;
        --green-100: #dcfce7;
        --green-50:  #f0fdf4;
        --zinc-900:  #18181b;
        --zinc-700:  #3f3f46;
        --zinc-500:  #71717a;
        --zinc-300:  #d4d4d8;
        --zinc-200:  #e4e4e7;
        --zinc-100:  #f4f4f5;
        --zinc-50:   #fafafa;
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { font-family: 'Outfit', system-ui, sans-serif; -webkit-text-size-adjust: 100%; }
      body { background: var(--zinc-50); color: var(--zinc-900); min-height: 100vh; }

      .page-bg {
        position: fixed; inset: 0; z-index: 0; pointer-events: none;
        background: var(--zinc-50);
        background-image: radial-gradient(circle, #d4d4d8 1px, transparent 1px);
        background-size: 20px 20px;
      }

      main { position: relative; z-index: 1; max-width: 44rem; margin: 0 auto;
             padding: 1.5rem 1rem 10rem; }
      @media (min-width: 640px) { main { padding-top: 2.5rem; padding-inline: 1.5rem; } }

      /* ── header ── */
      .page-header { margin-bottom: 1.75rem; }
      .eyebrow {
        display: inline-flex; align-items: center; gap: 0.375rem;
        background: var(--green-50); border: 1px solid var(--green-100);
        color: var(--green-800); font-size: 0.75rem; font-weight: 500;
        padding: 0.25rem 0.625rem; border-radius: 999px; margin-bottom: 0.875rem;
        letter-spacing: 0.01em;
      }
      .eyebrow svg { width: 13px; height: 13px; }
      h1 {
        font-family: 'Lora', Georgia, serif; font-size: 1.625rem; font-weight: 600;
        line-height: 1.25; color: var(--zinc-900); margin-bottom: 0.5rem;
        letter-spacing: -0.01em;
      }
      @media (min-width: 640px) { h1 { font-size: 2rem; } }
      .subtitle { font-size: 0.875rem; color: var(--zinc-500); line-height: 1.65; }
      .subtitle a { color: var(--green-700); font-weight: 500; text-underline-offset: 3px; }
      .subtitle a:hover { text-decoration: underline; }

      /* ── section label ── */
      .section-label {
        font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.08em;
        text-transform: uppercase; color: var(--zinc-500);
        margin-bottom: 0.875rem;
      }

      /* ── count badge ── */
      .count-badge {
        display: inline-block; background: var(--zinc-100); color: var(--zinc-500);
        font-size: 0.75rem; font-weight: 600; padding: 0.125rem 0.5rem;
        border-radius: 999px; margin-left: 0.375rem; vertical-align: middle;
      }

      /* ── farmacia grid ── */
      .farmacia-grid { display: flex; flex-direction: column; gap: 0.625rem; }
      @media (min-width: 560px) {
        .farmacia-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
      }
      @media (min-width: 860px) {
        .farmacia-grid { grid-template-columns: 1fr 1fr 1fr; }
      }

      /* ── card ── */
      .farmacia-card {
        background: #fff; border: 1px solid var(--zinc-200);
        border-radius: 1rem; padding: 1rem;
        display: flex; flex-direction: column; gap: 0;
        transition: border-color 0.15s, box-shadow 0.15s;
      }
      .farmacia-card:hover {
        border-color: #86efac;
        box-shadow: 0 2px 12px rgba(22,163,74,0.08);
      }

      .farmacia-nombre {
        font-family: 'Lora', Georgia, serif; font-size: 1rem; font-weight: 600;
        color: var(--zinc-900); line-height: 1.3; margin-bottom: 0.625rem;
      }

      .farmacia-dir, .farmacia-tel {
        display: flex; align-items: flex-start; gap: 0.375rem;
        font-size: 0.8125rem; color: var(--zinc-500); line-height: 1.5;
      }
      .farmacia-dir { margin-bottom: 0.5rem; }
      .farmacia-dir svg, .farmacia-tel svg {
        width: 14px; height: 14px; flex-shrink: 0; margin-top: 2px;
        color: var(--zinc-300);
      }

      /* tel link — big tap target */
      .farmacia-tel { margin-top: 0.5rem; padding-top: 0.5rem; border-top: 1px solid var(--zinc-100); }
      .tel-link {
        display: flex; align-items: center; gap: 0.375rem;
        min-height: 44px; font-weight: 500;
        color: var(--green-800); text-underline-offset: 3px;
        font-size: 0.9375rem;
        transition: color 0.15s;
        text-decoration: none;
      }
      .tel-link:hover { color: var(--green-600); text-decoration: underline; }
      .tel-link svg { width: 15px; height: 15px; flex-shrink: 0; color: var(--green-600); }

      /* ── FAQ ── */
      .faq { margin-top: 2.5rem; border-top: 1px solid var(--zinc-200); padding-top: 2rem; }
      .faq h2 { font-family: 'Lora', Georgia, serif; font-size: 1.125rem; font-weight: 600;
                color: var(--zinc-900); margin-bottom: 1.25rem; }
      details { border-bottom: 1px solid var(--zinc-200); padding-block: 0.875rem; }
      details:last-child { border-bottom: none; }
      summary {
        font-size: 0.9375rem; font-weight: 500; color: var(--zinc-900);
        cursor: pointer; list-style: none; display: flex; justify-content: space-between;
        align-items: center; gap: 0.75rem;
      }
      summary::-webkit-details-marker { display: none; }
      summary::after { content: "+"; font-size: 1.25rem; font-weight: 400; color: var(--zinc-500); flex-shrink: 0; }
      details[open] summary::after { content: "−"; }
      details p { font-size: 0.875rem; color: var(--zinc-500); line-height: 1.65;
                  margin-top: 0.625rem; padding-right: 1.5rem; }
    </style>

    <Analytics />
  </head>

  <body>
    <div class="page-bg" aria-hidden="true"></div>

    <FloatingNav client:idle activePath="/farmacias" />

    <main>
      <!-- ── Header ── -->
      <header class="page-header">
        <div class="eyebrow">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
          </svg>
          Monte Caseros, Corrientes
        </div>
        <h1>Directorio de farmacias</h1>
        <p class="subtitle">
          Teléfonos y direcciones de todas las farmacias de turno en Monte Caseros.
          Tocá el número para llamar directamente. Ver
          <a href="/calendario">próximos turnos</a> o
          <a href="/">farmacia de turno hoy</a>.
        </p>
      </header>

      <!-- ── Farmacia list ── -->
      <section aria-labelledby="farma-list-title">
        <h2 id="farma-list-title" class="sr-only">Listado de farmacias de Monte Caseros</h2>

        <p class="section-label">
          Farmacias
          <span class="count-badge" aria-label={`${farmaciaEntries.length} farmacias`}>
            {farmaciaEntries.length}
          </span>
        </p>

        <div class="farmacia-grid">
          {
            farmaciaEntries.map(([key, farma]) => (
              <article
                id={`farmacia-${slug(key)}`}
                class="farmacia-card"
                aria-label={farma.nombre}
                itemscope
                itemtype="https://schema.org/Pharmacy"
              >
                <h3 class="farmacia-nombre" itemprop="name">{farma.nombre}</h3>

                <p class="farmacia-dir" itemprop="address" itemscope itemtype="https://schema.org/PostalAddress">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                  </svg>
                  <span itemprop="streetAddress">{farma.direccion}</span>
                  <meta itemprop="addressLocality" content="Monte Caseros" />
                  <meta itemprop="addressRegion" content="Corrientes" />
                  <meta itemprop="addressCountry" content="AR" />
                </p>

                {farma.telefono && (
                  <p class="farmacia-tel">
                    <a
                      href={`tel:${farma.telefono.replace(/\s/g, "")}`}
                      class="tel-link"
                      itemprop="telephone"
                      aria-label={`Llamar a ${farma.nombre}: ${farma.telefono}`}
                    >
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                      </svg>
                      {farma.telefono}
                    </a>
                  </p>
                )}
              </article>
            ))
          }
        </div>
      </section>

      <!-- ── FAQ ── -->
      <section class="faq" aria-labelledby="faq-dir-title">
        <h2 id="faq-dir-title">Preguntas frecuentes</h2>

        <details>
          <summary>¿Cómo llamo a una farmacia desde el celular?</summary>
          <p>Tocá el número de teléfono en la ficha: tu celular abrirá el marcador con el número ya cargado, listo para llamar.</p>
        </details>

        <details>
          <summary>¿Estas son todas las farmacias de Monte Caseros?</summary>
          <p>El listado incluye todas las farmacias que participan en la rotación del calendario oficial de turnos de Monte Caseros, Corrientes.</p>
        </details>

        <details>
          <summary>¿Dónde veo cuál está de turno hoy?</summary>
          <p>En la <a href="/" style="color: var(--green-700); font-weight: 500;">página de inicio</a> encontrás la farmacia de turno actual con mapa y teléfono. En <a href="/calendario" style="color: var(--green-700); font-weight: 500;">Calendario</a> podés ver los próximos días.</p>
        </details>
      </section>

      <SecondaryPageInfo />
    </main>
  </body>
</html>